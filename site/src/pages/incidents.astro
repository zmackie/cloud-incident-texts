---
import Base from "../layouts/Base.astro";
---
<Base title="Incidents" description="Browse all analyzed cloud security incidents">
  <div class="page">
    <div class="page-header">
      <h1 class="page-title">Incidents</h1>
      <p class="page-subtitle">
        Browse all analyzed cloud security incidents with their ATT&CK technique mappings.
      </p>
    </div>

    <div class="filters" id="filters">
      <input
        id="search"
        type="text"
        placeholder="Search incidents…"
        autocomplete="off"
      />
      <select id="filter-impact">
        <option value="">All impact types</option>
      </select>
      <select id="filter-service">
        <option value="">All services</option>
      </select>
      <select id="group-by">
        <option value="none">No grouping</option>
        <option value="year">Group by year</option>
        <option value="impact">Group by impact category</option>
        <option value="service">Group by primary service</option>
      </select>
      <span id="result-count" class="result-count"></span>
    </div>

    <div id="incidents-grid" class="incidents-grid">
      <div class="loading">Loading incidents…</div>
    </div>
  </div>
</Base>

<style is:global>
  .filters {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .filters input,
  .filters select {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: var(--radius);
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    font-family: var(--font-body);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .filters input { min-width: 240px; flex: 1; }
  .filters input:focus,
  .filters select:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 2px var(--blue-dim);
  }

  .result-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-left: auto;
    font-family: var(--font-mono);
  }

  .incidents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 0.875rem;
  }

  .group-block { margin-bottom: 2rem; grid-column: 1 / -1; }
  .group-title {
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .incident-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.25rem 1.25rem 1.1rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: border-color 0.15s, transform 0.1s, box-shadow 0.15s;
  }

  .incident-card:hover {
    border-color: var(--blue);
    border-left-color: var(--blue);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    text-decoration: none;
  }

  .incident-name {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--text);
  }

  .incident-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .impact-badge {
    font-size: 0.68rem;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border: 1px solid;
    white-space: nowrap;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .techniques-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .incident-card:hover .tech-badge {
    color: var(--text);
  }

  .services-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .card-technique-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }
</style>

<script>
const DATA_BASE = `${import.meta.env.BASE_URL}/data`;

function esc(s: unknown): string {
  return String(s ?? "")
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

let allIncidents: any[] = [];
let catalog: any = {};

async function loadIncidents() {
  const [index, stats, catalogData] = await Promise.all([
    fetch(`${DATA_BASE}/incidents_index.json`).then(r => r.ok ? r.json() : []),
    fetch(`${DATA_BASE}/stats.json`).then(r => r.ok ? r.json() : {}),
    fetch(`${DATA_BASE}/catalog.json`).then(r => r.ok ? r.json() : {}),
  ]);
  return { index, stats, catalogData };
}

function impactColor(impact: string): string {
  const s = impact.toLowerCase();
  if (s.includes("ransomware")) return "#bc8cff";
  if (s.includes("cryptomining") || s.includes("cryptojacking")) return "#d29922";
  if (s.includes("exfiltration") || s.includes("data breach") || s.includes("credential")) return "#f47067";
  if (s.includes("disruption") || s.includes("destruction") || s.includes("denial")) return "#58a6ff";
  if (s.includes("phishing") || s.includes("ses abuse")) return "#e09e52";
  if (s.includes("account takeover")) return "#3bb5a0";
  if (s.includes("llmjacking") || s.includes("resource hijacking")) return "#c548b5";
  return "#ff6b35";
}

function renderCard(inc: any): HTMLElement {
  const card = document.createElement("a");
  card.href = `${import.meta.env.BASE_URL}/incident?slug=${encodeURIComponent(inc.slug)}`;
  card.className = "incident-card";

  const impactLower = (inc.impact_type || "").toLowerCase();
  const borderColor = impactColor(inc.impact_type || "");
  card.style.borderLeftColor = borderColor;

  const confPct = Math.round((inc.confidence_score || 0) * 100);
  const techniques = (inc.technique_ids || []).slice(0, 6);
  const services = (inc.aws_services || []).slice(0, 4);
  const totalTechniques = (inc.technique_ids || []).length;

  // Extract year from slug (format: "name-YYYY-month")
  const slugMatch = inc.slug.match(/(19\d{2}|20\d{2})/);
  const year = slugMatch ? slugMatch[1] : "";

  card.innerHTML = `
    <div class="incident-name">${esc(inc.name)}</div>
    <div class="incident-meta">
      ${inc.impact_type ? `<span class="impact-badge" style="color:${borderColor};border-color:${borderColor}40;background:${borderColor}20">${esc(inc.impact_type)}</span>` : ""}
      ${services.length ? services.map((s: string) => `<span class="badge">${esc(s)}</span>`).join("") : ""}
    </div>
    ${techniques.length ? `<div class="techniques-list">${techniques.map((t: string) => `<span class="tech-badge">${esc(t)}</span>`).join("")}${totalTechniques > 6 ? `<span class="tech-badge">+${totalTechniques - 6}</span>` : ""}</div>` : ""}
    <div class="card-footer">
      <span class="card-date">${esc(year)}</span>
      <span class="card-technique-count">${totalTechniques} technique${totalTechniques !== 1 ? "s" : ""}</span>
    </div>
  `;

  return card;
}

function renderGrid(incidents: any[]) {
  const grid = document.getElementById("incidents-grid")!;
  grid.innerHTML = "";

  if (incidents.length === 0) {
    grid.innerHTML = `<div class="loading" style="color:var(--text-muted)">No incidents match your filters.</div>`;
    return;
  }

  const mode = (document.getElementById("group-by") as HTMLSelectElement).value;
  const grouped = new Map<string, any[]>();

  function impactCategory(impact: string): string {
    const s = (impact || "").toLowerCase();
    if (s.includes("ransomware")) return "Ransomware";
    if (s.includes("cryptomining") || s.includes("cryptojacking")) return "Cryptomining";
    if (s.includes("llmjacking") || s.includes("resource hijacking")) return "LLM / Resource Hijacking";
    if (s.includes("exfiltration") || s.includes("data breach")) return "Data Exfiltration";
    if (s.includes("destruction") || s.includes("disruption") || s.includes("denial")) return "Service / Data Destruction";
    if (s.includes("credential")) return "Credential Theft";
    if (s.includes("phishing") || s.includes("ses abuse") || s.includes("smishing") || s.includes("sms")) return "Phishing / SES Abuse";
    if (s.includes("account takeover")) return "Account Takeover";
    if (s.includes("financial") || s.includes("cryptocurrency")) return "Financial Theft";
    if (s.includes("supply chain") || s.includes("magecart") || s.includes("nft")) return "Supply Chain";
    return impact ? "Other" : "Unknown";
  }

  if (mode === "none") {
    grouped.set(`All incidents`, incidents);
  } else if (mode === "year") {
    for (const inc of incidents) {
      const m = inc.slug.match(/(19\d{2}|20\d{2})/);
      const key = m ? m[1] : "Undated";
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key)!.push(inc);
    }
    // Sort descending by year
    const sorted = new Map([...grouped.entries()].sort((a, b) => b[0].localeCompare(a[0])));
    grouped.clear();
    for (const [k, v] of sorted) grouped.set(k, v);
  } else if (mode === "impact") {
    for (const inc of incidents) {
      const key = impactCategory(inc.impact_type || "");
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key)!.push(inc);
    }
    // Sort descending by bucket size
    const sorted = new Map([...grouped.entries()].sort((a, b) => b[1].length - a[1].length));
    grouped.clear();
    for (const [k, v] of sorted) grouped.set(k, v);
  } else if (mode === "service") {
    for (const inc of incidents) {
      const svc = (inc.aws_services || [])[0];
      const key = svc ? svc.replace(/^(AWS |Amazon )/, "") : "No service tagged";
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key)!.push(inc);
    }
    const sorted = new Map([...grouped.entries()].sort((a, b) => b[1].length - a[1].length));
    grouped.clear();
    for (const [k, v] of sorted) grouped.set(k, v);
  }

  for (const [groupName, members] of grouped.entries()) {
    const block = document.createElement("div");
    block.className = "group-block";
    block.innerHTML = `<div class="group-title">${esc(groupName)} · ${members.length}</div>`;
    const cards = document.createElement("div");
    cards.className = "incidents-grid";
    for (const inc of members) cards.appendChild(renderCard(inc));
    block.appendChild(cards);
    grid.appendChild(block);
  }

  const countEl = document.getElementById("result-count")!;
  countEl.textContent = `${incidents.length} incident${incidents.length !== 1 ? "s" : ""}`;
}

function applyFilters() {
  const search = (document.getElementById("search") as HTMLInputElement).value.toLowerCase();
  const impact = (document.getElementById("filter-impact") as HTMLSelectElement).value;
  const service = (document.getElementById("filter-service") as HTMLSelectElement).value;

  const filtered = allIncidents.filter(inc => {
    if (search && !inc.name.toLowerCase().includes(search) &&
        !inc.slug.toLowerCase().includes(search) &&
        !(inc.technique_ids || []).some((t: string) => t.toLowerCase().includes(search))) {
      return false;
    }
    if (impact && inc.impact_type !== impact) return false;
    if (service && !(inc.aws_services || []).includes(service)) return false;
    return true;
  });

  // Check for technique filter from URL
  const params = new URLSearchParams(window.location.search);
  const techFilter = params.get("technique");
  if (techFilter) {
    renderGrid(filtered.filter(inc => (inc.technique_ids || []).includes(techFilter)));
    return;
  }

  renderGrid(filtered);
}

async function init() {
  try {
    const { index, stats, catalogData } = await loadIncidents();

    if (!index || index.length === 0) {
      document.getElementById("incidents-grid")!.innerHTML =
        `<div class="loading" style="color:var(--text-muted)">No incidents analyzed yet. Run the pipeline first.</div>`;
      return;
    }

    allIncidents = index;
    catalog = catalogData || {};

    // Populate filter dropdowns
    const impactTypes = [...new Set(index.map((i: any) => i.impact_type).filter(Boolean))].sort();
    const impactSel = document.getElementById("filter-impact") as HTMLSelectElement;
    for (const t of impactTypes) {
      const opt = document.createElement("option");
      opt.value = t as string;
      opt.textContent = t as string;
      impactSel.appendChild(opt);
    }

    const allServices = [...new Set(index.flatMap((i: any) => i.aws_services || []))].sort();
    const serviceSel = document.getElementById("filter-service") as HTMLSelectElement;
    for (const s of allServices) {
      const opt = document.createElement("option");
      opt.value = s as string;
      opt.textContent = s as string;
      serviceSel.appendChild(opt);
    }

    // Handle technique pre-filter from URL
    const params = new URLSearchParams(window.location.search);
    const techFilter = params.get("technique");
    const searchEl = document.getElementById("search") as HTMLInputElement;
    if (techFilter) {
      searchEl.value = techFilter;
    }

    searchEl.addEventListener("input", applyFilters);
    impactSel.addEventListener("change", applyFilters);
    serviceSel.addEventListener("change", applyFilters);
    (document.getElementById("group-by") as HTMLSelectElement).addEventListener("change", applyFilters);

    applyFilters();
  } catch (err) {
    document.getElementById("incidents-grid")!.innerHTML =
      `<div class="loading" style="color:var(--text-muted)">Failed to load incidents.</div>`;
    console.error(err);
  }
}

init();
</script>

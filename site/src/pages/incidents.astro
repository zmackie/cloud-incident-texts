---
import Base from "../layouts/Base.astro";
---
<Base title="Incidents" description="Browse all analyzed cloud security incidents">
  <div class="page">
    <div class="page-header">
      <h1 class="page-title">Incidents</h1>
      <p class="page-subtitle">
        Browse all analyzed cloud security incidents with their ATT&CK technique mappings.
      </p>
    </div>

    <div class="filters" id="filters">
      <input
        id="search"
        type="text"
        placeholder="Search incidents…"
        autocomplete="off"
      />
      <select id="filter-impact">
        <option value="">All impact types</option>
      </select>
      <select id="filter-service">
        <option value="">All services</option>
      </select>
      <div class="layout-control">
        <label class="layout-label" for="group-by">Layout</label>
        <select id="group-by">
          <option value="none">Flat list</option>
          <option value="year">By year</option>
          <option value="impact">By impact category</option>
          <option value="service">By primary service</option>
        </select>
      </div>
      <span id="result-count" class="result-count"></span>
    </div>
    <div id="layout-status" class="layout-status"></div>

    <div id="incidents-grid" class="incidents-grid">
      <div class="loading">Loading incidents…</div>
    </div>
  </div>
</Base>

<style is:global>
  .filters {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .filters input,
  .filters select {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: var(--radius);
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    font-family: var(--font-body);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .filters input { min-width: 240px; flex: 1; }
  .filters input:focus,
  .filters select:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 2px var(--blue-dim);
  }

  .result-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-left: auto;
    font-family: var(--font-mono);
  }

  .layout-control {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .layout-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .layout-status {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin: -0.5rem 0 1.25rem 0.25rem;
  }

  .incidents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 0.875rem;
  }

  .group-block { margin-bottom: 2rem; grid-column: 1 / -1; }
  .group-title {
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .incident-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.25rem 1.25rem 1.1rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: border-color 0.15s, transform 0.1s, box-shadow 0.15s;
  }

  .incident-card:hover {
    border-color: var(--blue);
    border-left-color: var(--blue);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    text-decoration: none;
  }

  .incident-name {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--text);
  }

  .incident-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .impact-badge {
    font-size: 0.68rem;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border: 1px solid;
    white-space: nowrap;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .techniques-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .incident-card:hover .tech-badge {
    color: var(--text);
  }

  /* Chain signature — ordinal strip of tactic-colored dots on a hairline.
     One dot per attack_chain step. Inferred steps render hollow. */
  .chain-signature {
    position: relative;
    height: 18px;
    display: flex;
    align-items: center;
    margin: 0.15rem 0 0.1rem;
  }

  .chain-signature .cs-rail {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: var(--border);
    transform: translateY(-0.5px);
  }

  .chain-signature .cs-dots {
    position: relative;
    display: flex;
    gap: 6px;
    flex: 1;
    min-width: 0;
    align-items: center;
  }

  .chain-signature .cs-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--text-muted);
    box-shadow: 0 0 0 3px var(--bg-secondary);
    transition: transform 0.15s;
  }

  .incident-card:hover .chain-signature .cs-dot {
    transform: scale(1.1);
  }

  .chain-signature .cs-dot.inferred {
    background: transparent;
    border: 1.5px solid var(--yellow);
  }

  .chain-signature .cs-overflow {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-muted);
    padding-left: 6px;
    background: var(--bg-secondary);
    z-index: 1;
    letter-spacing: 0.04em;
  }

  .services-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .card-technique-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }
</style>

<script>
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const DATA_BASE = `${BASE}/data`;

function esc(s: unknown): string {
  return String(s ?? "")
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

let allIncidents: any[] = [];

async function loadIncidents() {
  const [index, stats] = await Promise.all([
    fetch(`${DATA_BASE}/incidents_index.json`).then(r => r.ok ? r.json() : []),
    fetch(`${DATA_BASE}/stats.json`).then(r => r.ok ? r.json() : {}),
  ]);
  return { index, stats };
}

const TACTIC_COLORS: Record<string, string> = {
  "TA0043": "#e05252", "TA0042": "#e07852", "TA0001": "#e09e52",
  "TA0002": "#c5a832", "TA0003": "#8fb83e", "TA0004": "#4ab56e",
  "TA0005": "#3bb5a0", "TA0006": "#3898c5", "TA0007": "#4872c5",
  "TA0008": "#6456c5", "TA0009": "#9048c5", "TA0011": "#c548b5",
  "TA0010": "#c5486e", "TA0040": "#c5485a",
};

const SIGNATURE_MAX = 12;

function renderChainSignature(signature: any[]): string {
  if (!signature?.length) return "";
  const visible = signature.slice(0, SIGNATURE_MAX);
  const overflow = signature.length - visible.length;
  const dots = visible.map((step) => {
    const color = TACTIC_COLORS[step?.ta] || "#7d8590";
    const inferred = !!step?.inferred;
    return inferred
      ? `<span class="cs-dot inferred" style="border-color:${color}"></span>`
      : `<span class="cs-dot" style="background:${color}"></span>`;
  }).join("");
  const overflowLabel = overflow > 0
    ? `<span class="cs-overflow">+${overflow}</span>`
    : "";
  return `
    <div class="chain-signature" aria-hidden="true">
      <span class="cs-rail"></span>
      <div class="cs-dots">${dots}${overflowLabel}</div>
    </div>`;
}

// impact_type is already canonicalized in build_site_data.py (see
// scripts/normalize.py). Keys match CANONICAL_IMPACTS exactly.
const IMPACT_COLORS: Record<string, string> = {
  "Ransomware / Extortion": "#bc8cff",
  "Cryptomining": "#d29922",
  "Data Exfiltration": "#f47067",
  "Data Destruction / Disruption": "#58a6ff",
  "Phishing / SES Abuse": "#e09e52",
  "Account Takeover": "#3bb5a0",
  "LLM / Resource Hijacking": "#c548b5",
  "Credential Theft": "#f47067",
  "Financial Theft": "#ff6b35",
  "Supply Chain": "#ff6b35",
  "Unauthorized Access": "#7d8590",
};

function impactColor(impact: string): string {
  return IMPACT_COLORS[impact] || "#7d8590";
}

function renderCard(inc: any): HTMLElement {
  const card = document.createElement("a");
  card.href = `${BASE}/incident?slug=${encodeURIComponent(inc.slug)}`;
  card.className = "incident-card";

  const borderColor = impactColor(inc.impact_type || "");
  card.style.borderLeftColor = borderColor;

  const confPct = Math.round((inc.confidence_score || 0) * 100);
  const services = (inc.aws_services || []).slice(0, 4);
  const signature = inc.chain_signature || [];
  const stepCount = signature.length;
  // Legacy fallback: when chain_signature is absent (e.g. stale build output)
  // render today's layout so the grid never looks broken mid-deploy.
  const hasSignature = stepCount > 0;
  const legacyTechniques = (inc.technique_ids || []).slice(0, 6);
  const legacyTechniqueTotal = (inc.technique_ids || []).length;

  // Prefer event_date (from build_site_data.py); fall back to LAST year in slug
  // so threat-group codes like UNC4899 don't get picked up before the real year.
  let year = "";
  if (inc.event_date && /^\d{4}/.test(String(inc.event_date))) {
    year = String(inc.event_date).slice(0, 4);
  } else {
    const matches = Array.from(inc.slug.matchAll(/(19\d{2}|20\d{2})/g));
    if (matches.length) year = matches[matches.length - 1][1];
  }

  const footerCount = hasSignature
    ? `${stepCount} STEP${stepCount !== 1 ? "S" : ""}`
    : `${legacyTechniqueTotal} TECHNIQUE${legacyTechniqueTotal !== 1 ? "S" : ""}`;

  const middleRow = hasSignature
    ? renderChainSignature(signature)
    : (legacyTechniques.length
        ? `<div class="techniques-list">${legacyTechniques.map((t: string) => `<span class="tech-badge">${esc(t)}</span>`).join("")}${legacyTechniqueTotal > 6 ? `<span class="tech-badge">+${legacyTechniqueTotal - 6}</span>` : ""}</div>`
        : "");

  card.innerHTML = `
    <div class="incident-name">${esc(inc.name)}</div>
    <div class="incident-meta">
      ${inc.impact_type ? `<span class="impact-badge" style="color:${borderColor};border-color:${borderColor}40;background:${borderColor}20">${esc(inc.impact_type)}</span>` : ""}
      ${services.length ? services.map((s: string) => `<span class="badge">${esc(s)}</span>`).join("") : ""}
    </div>
    ${middleRow}
    <div class="card-footer">
      <span class="card-date">${esc(year)}</span>
      <span class="card-technique-count">${footerCount}</span>
    </div>
  `;

  return card;
}

function renderGrid(incidents: any[]) {
  const grid = document.getElementById("incidents-grid")!;
  grid.innerHTML = "";

  if (incidents.length === 0) {
    grid.innerHTML = `<div class="loading" style="color:var(--text-muted)">No incidents match your filters.</div>`;
    return;
  }

  const mode = (document.getElementById("group-by") as HTMLSelectElement).value;
  const grouped = new Map<string, any[]>();

  if (mode === "none") {
    grouped.set(`All incidents`, incidents);
  } else if (mode === "year") {
    for (const inc of incidents) {
      // Use event_date when present (build_site_data.py adds it when available),
      // else last 19xx/20xx match in slug — slugs often embed a threat-group
      // code (e.g. UNC4899) or an older year in the name, so trailing wins.
      let key = "Undated";
      if (inc.event_date && /^\d{4}/.test(String(inc.event_date))) {
        key = String(inc.event_date).slice(0, 4);
      } else {
        const matches = Array.from(inc.slug.matchAll(/(19\d{2}|20\d{2})/g));
        if (matches.length) key = matches[matches.length - 1][1];
      }
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key)!.push(inc);
    }
    // Sort descending by year; non-numeric buckets (e.g. "Undated") go last.
    const sorted = new Map([...grouped.entries()].sort((a, b) => {
      const aNum = /^\d{4}$/.test(a[0]);
      const bNum = /^\d{4}$/.test(b[0]);
      if (aNum && !bNum) return -1;
      if (!aNum && bNum) return 1;
      if (!aNum && !bNum) return a[0].localeCompare(b[0]);
      return b[0].localeCompare(a[0]);
    }));
    grouped.clear();
    for (const [k, v] of sorted) grouped.set(k, v);
  } else if (mode === "impact") {
    for (const inc of incidents) {
      const key = inc.impact_type || "Unknown";
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key)!.push(inc);
    }
    // Sort descending by bucket size
    const sorted = new Map([...grouped.entries()].sort((a, b) => b[1].length - a[1].length));
    grouped.clear();
    for (const [k, v] of sorted) grouped.set(k, v);
  } else if (mode === "service") {
    for (const inc of incidents) {
      const svc = (inc.aws_services || [])[0];
      const key = svc ? svc.replace(/^(AWS |Amazon )/, "") : "No service tagged";
      if (!grouped.has(key)) grouped.set(key, []);
      grouped.get(key)!.push(inc);
    }
    const sorted = new Map([...grouped.entries()].sort((a, b) => b[1].length - a[1].length));
    grouped.clear();
    for (const [k, v] of sorted) grouped.set(k, v);
  }

  for (const [groupName, members] of grouped.entries()) {
    const block = document.createElement("div");
    block.className = "group-block";
    block.innerHTML = `<div class="group-title">${esc(groupName)} · ${members.length}</div>`;
    const cards = document.createElement("div");
    cards.className = "incidents-grid";
    for (const inc of members) cards.appendChild(renderCard(inc));
    block.appendChild(cards);
    grid.appendChild(block);
  }

  const countEl = document.getElementById("result-count")!;
  countEl.textContent = `${incidents.length} incident${incidents.length !== 1 ? "s" : ""}`;

  const statusEl = document.getElementById("layout-status")!;
  if (mode === "none") {
    // Flat list mode: the "All incidents · N" group header already communicates this.
    statusEl.textContent = "";
  } else {
    const modeName = { year: "YEAR", impact: "IMPACT CATEGORY", service: "PRIMARY SERVICE" }[mode] || mode.toUpperCase();
    statusEl.textContent = `GROUPED BY ${modeName} · ${grouped.size} BUCKET${grouped.size !== 1 ? "S" : ""} · ${incidents.length} INCIDENTS`;
  }
}

function applyFilters() {
  const search = (document.getElementById("search") as HTMLInputElement).value.toLowerCase();
  const impact = (document.getElementById("filter-impact") as HTMLSelectElement).value;
  const service = (document.getElementById("filter-service") as HTMLSelectElement).value;

  const filtered = allIncidents.filter(inc => {
    if (search && !inc.name.toLowerCase().includes(search) &&
        !inc.slug.toLowerCase().includes(search) &&
        !(inc.technique_ids || []).some((t: string) => t.toLowerCase().includes(search))) {
      return false;
    }
    if (impact && inc.impact_type !== impact) return false;
    if (service && !(inc.aws_services || []).includes(service)) return false;
    return true;
  });

  // Check for technique filter from URL
  const params = new URLSearchParams(window.location.search);
  const techFilter = params.get("technique");
  if (techFilter) {
    renderGrid(filtered.filter(inc => (inc.technique_ids || []).includes(techFilter)));
    return;
  }

  renderGrid(filtered);
}

async function init() {
  try {
    const { index } = await loadIncidents();

    if (!index || index.length === 0) {
      document.getElementById("incidents-grid")!.innerHTML =
        `<div class="loading" style="color:var(--text-muted)">No incidents analyzed yet. Run the pipeline first.</div>`;
      return;
    }

    allIncidents = index;

    // Populate filter dropdowns
    const impactTypes = [...new Set(index.map((i: any) => i.impact_type).filter(Boolean))].sort();
    const impactSel = document.getElementById("filter-impact") as HTMLSelectElement;
    for (const t of impactTypes) {
      const opt = document.createElement("option");
      opt.value = t as string;
      opt.textContent = t as string;
      impactSel.appendChild(opt);
    }

    const allServices = [...new Set(index.flatMap((i: any) => i.aws_services || []))].sort();
    const serviceSel = document.getElementById("filter-service") as HTMLSelectElement;
    for (const s of allServices) {
      const opt = document.createElement("option");
      opt.value = s as string;
      opt.textContent = s as string;
      serviceSel.appendChild(opt);
    }

    // Handle technique pre-filter from URL
    const params = new URLSearchParams(window.location.search);
    const techFilter = params.get("technique");
    const searchEl = document.getElementById("search") as HTMLInputElement;
    if (techFilter) {
      searchEl.value = techFilter;
    }

    searchEl.addEventListener("input", applyFilters);
    impactSel.addEventListener("change", applyFilters);
    serviceSel.addEventListener("change", applyFilters);
    (document.getElementById("group-by") as HTMLSelectElement).addEventListener("change", applyFilters);

    applyFilters();
  } catch (err) {
    document.getElementById("incidents-grid")!.innerHTML =
      `<div class="loading" style="color:var(--text-muted)">Failed to load incidents.</div>`;
    console.error(err);
  }
}

init();
</script>

# Copy this file to .env and fill in your values.
# The crawler works without any of these; they unlock higher rate limits
# and enable fallback OCR for content that jina.ai can't reach.

# Optional: raises jina.ai reader rate limit (free without key, ~20 req/min)
# Get one at https://jina.ai/reader/
JINA_API_KEY=jina_...

# Optional: enables Claude vision OCR for scanned PDFs / last-resort fallback
ANTHROPIC_API_KEY=sk-ant-...

# Optional: raises GitHub API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_...

---
// "Anatomy of Cloud Attacks" — editorial ranked-bar visualization
// Replaces the dense MITRE matrix with a story-first layout
---
<div class="anatomy">
  <div class="loading" id="anatomy-loading">Loading field data…</div>
</div>

<div class="tooltip" id="heatmap-tooltip"></div>

<style is:global>
  .anatomy { display: flex; flex-direction: column; gap: 3rem; }

  /* ── Top-N ranked list ────────────────────────────────── */
  .top-techniques {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 1.5rem;
  }

  .top-row {
    display: contents;
  }

  .top-row .rank-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    font-variation-settings: "opsz" 96;
    color: var(--text-muted);
    text-align: right;
    padding: 0.9rem 0 0;
    font-feature-settings: "tnum";
    line-height: 1;
    min-width: 3.25rem;
  }

  .top-row .rank-num[data-top="1"] { color: var(--text); font-weight: 500; }

  .top-row .rank-content {
    padding: 0.75rem 0 1rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    cursor: pointer;
    transition: background 0.1s;
  }

  .top-row:last-child .rank-content { border-bottom: none; }

  .top-row .rank-content:hover {
    background: linear-gradient(90deg, transparent, var(--bg-secondary) 30%, var(--bg-secondary) 70%, transparent);
    margin: 0 -0.5rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }

  .top-row .rank-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .top-row .tech-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    font-variation-settings: "opsz" 36;
    color: var(--text);
    line-height: 1.15;
  }

  .top-row .tech-id {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    padding: 1px 6px;
    border: 1px solid var(--border);
    border-radius: 3px;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .top-row .tech-tactic {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .top-row .tech-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.1rem;
  }

  .top-row .bar-track {
    flex: 1;
    height: 6px;
    background: var(--bg-tertiary);
    border-radius: 3px;
    overflow: hidden;
    min-width: 80px;
  }

  .top-row .bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.4s cubic-bezier(.2,.8,.2,1);
  }

  .top-row .count {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    font-variation-settings: "opsz" 36;
    color: var(--text);
    font-feature-settings: "tnum";
    min-width: 2.5rem;
    text-align: right;
  }

  .top-row .count-pct {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    min-width: 2.8rem;
  }

  /* ── Kill-chain breakdown ──────────────────────────────── */
  .kill-chain-section {
    position: relative;
  }

  .section-label {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .section-label .kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .section-label h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-variation-settings: "opsz" 48;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .section-lead {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 60ch;
    line-height: 1.55;
    margin-bottom: 1.75rem;
  }

  .kill-chain {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .tactic-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-top: 3px solid var(--tactic-color, var(--accent));
    border-radius: var(--radius-lg);
    padding: 1rem 1.1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tactic-card .tactic-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .tactic-card .tactic-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    font-variation-settings: "opsz" 24;
    color: var(--tactic-color, var(--accent));
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .tactic-card .tactic-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .tactic-card .tactic-list {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .tactic-card .mini-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
    align-items: center;
    padding: 3px 0;
    font-size: 0.78rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 3px;
    transition: background 0.1s;
  }

  .tactic-card .mini-row:hover {
    background: var(--bg-tertiary);
    padding-left: 4px;
    padding-right: 4px;
    margin: 0 -4px;
  }

  .tactic-card .mini-row .mini-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text);
  }

  .tactic-card .mini-row .mini-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    font-feature-settings: "tnum";
    position: relative;
    padding-left: 40px;
  }

  .tactic-card .mini-row .mini-count::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: var(--mini-w, 0%);
    height: 2px;
    background: var(--tactic-color, var(--accent));
    opacity: 0.6;
    transform: translateY(-50%);
    border-radius: 1px;
  }

  .tactic-card .tactic-empty {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-style: italic;
    padding: 4px 0;
  }

  .tactic-card .tactic-more {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
    cursor: pointer;
  }

  .tactic-card .tactic-more:hover {
    color: var(--text);
  }
</style>

<script>
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const DATA_BASE = `${BASE}/data`;

function esc(s: unknown): string {
  return String(s ?? "")
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

const TACTIC_COLORS: Record<string, string> = {
  "TA0043": "#e05252", "TA0042": "#e07852", "TA0001": "#e09e52",
  "TA0002": "#c5a832", "TA0003": "#8fb83e", "TA0004": "#4ab56e",
  "TA0005": "#3bb5a0", "TA0006": "#3898c5", "TA0007": "#4872c5",
  "TA0008": "#6456c5", "TA0009": "#9048c5", "TA0011": "#c548b5",
  "TA0010": "#c5486e", "TA0040": "#c5485a", "": "#777",
};

const TACTIC_ORDER = [
  "TA0043", "TA0042", "TA0001", "TA0002", "TA0003", "TA0004", "TA0005",
  "TA0006", "TA0007", "TA0008", "TA0009", "TA0011", "TA0010", "TA0040",
];

async function loadData() {
  const [freqData, metaData, stats] = await Promise.all([
    fetch(`${DATA_BASE}/technique_frequency.json`).then(r => r.ok ? r.json() : {}),
    fetch(`${DATA_BASE}/attack_meta.json`).then(r => r.ok ? r.json() : {}),
    fetch(`${DATA_BASE}/stats.json`).then(r => r.ok ? r.json() : {}),
  ]);
  return { freqData, metaData, stats };
}

function render(freqData: Record<string, any>, metaData: Record<string, any>, stats: Record<string, any>) {
  const container = document.querySelector(".anatomy")! as HTMLElement;
  container.innerHTML = "";

  const techniques = metaData.techniques || {};
  const tactics = metaData.tactics || {};
  const totalIncidents = stats.total_incidents || 1;

  // Build enriched technique list with count.
  // Each technique carries ALL of its tactic_ids so the kill-chain
  // breakdown below can expand multi-tactic techniques (e.g. T1078.004
  // is simultaneously Defense Evasion / Persistence / Privilege Escalation
  // / Initial Access) into every applicable bucket instead of only the
  // first tactic_id.
  const allTechniques = Object.entries(freqData)
    .map(([tid, v]: [string, any]) => {
      const meta = techniques[tid] || {};
      const tacticIds: string[] = (meta.tactic_ids && meta.tactic_ids.length)
        ? meta.tactic_ids
        : (v.tactic_id ? [v.tactic_id] : []);
      const primaryTactic = tacticIds[0] || "";
      return {
        id: tid,
        name: meta.name || v.technique_name || tid,
        tacticIds,
        tacticId: primaryTactic,
        tacticName: (tactics[primaryTactic]?.name) || v.tactic_name || "",
        color: TACTIC_COLORS[primaryTactic] || "#777",
        count: v.count || 0,
        incidents: v.incidents || [],
      };
    })
    .filter((t: any) => t.count > 0)
    .sort((a: any, b: any) => b.count - a.count);

  const maxCount = allTechniques.length ? allTechniques[0].count : 1;

  // ── Section 1: Top 10 ranked ─────────────────────────────
  const topSection = document.createElement("section");
  topSection.className = "kill-chain-section";
  topSection.innerHTML = `
    <div class="section-label">
      <span class="kicker">Chapter One</span>
      <h2>The ten most-used techniques</h2>
    </div>
    <p class="section-lead">
      Of ${allTechniques.length} MITRE ATT&CK techniques observed across ${totalIncidents} public cloud incidents,
      these ten account for the bulk of attacker behavior. Bars are scaled to the most-observed technique.
    </p>
    <div class="top-techniques" id="top-techniques"></div>
  `;
  container.appendChild(topSection);

  const topList = topSection.querySelector("#top-techniques")!;
  const top10 = allTechniques.slice(0, 10);
  top10.forEach((t, i) => {
    const pct = Math.round((t.count / totalIncidents) * 100);
    const barWidth = Math.max(4, (t.count / maxCount) * 100);
    const row = document.createElement("div");
    row.className = "top-row";
    row.innerHTML = `
      <div class="rank-num" data-top="${i + 1}">${String(i + 1).padStart(2, "0")}</div>
      <div class="rank-content" data-tid="${esc(t.id)}">
        <div class="rank-head">
          <span class="tech-name">${esc(t.name)}</span>
          <span class="tech-id">${esc(t.id)}</span>
          <span class="tech-tactic" style="color:${t.color}">${esc(t.tacticName)}</span>
        </div>
        <div class="tech-meta">
          <div class="bar-track">
            <div class="bar-fill" style="width:${barWidth}%;background:${t.color}"></div>
          </div>
          <span class="count">${t.count}</span>
          <span class="count-pct">${pct}%</span>
        </div>
      </div>
    `;
    row.querySelector(".rank-content")!.addEventListener("click", () => {
      window.location.href = `${BASE}/incidents?technique=${t.id}`;
    });
    topList.appendChild(row);
  });

  // ── Section 2: Kill chain breakdown ──────────────────────
  const chainSection = document.createElement("section");
  chainSection.className = "kill-chain-section";
  chainSection.innerHTML = `
    <div class="section-label">
      <span class="kicker">Chapter Two</span>
      <h2>The cloud kill chain</h2>
    </div>
    <p class="section-lead">
      Techniques grouped by their position in MITRE's kill chain — from reconnaissance through impact.
      Each card shows the top five techniques observed in that tactic.
    </p>
    <div class="kill-chain" id="kill-chain"></div>
  `;
  container.appendChild(chainSection);

  const chainGrid = chainSection.querySelector("#kill-chain")!;

  // Group techniques by tactic. Multi-tactic techniques appear in every
  // applicable bucket so the kill-chain grid reflects real coverage
  // rather than each technique's metadata-first tactic.
  const byTactic: Record<string, any[]> = {};
  for (const t of allTechniques) {
    for (const tid of t.tacticIds) {
      if (!byTactic[tid]) byTactic[tid] = [];
      byTactic[tid].push(t);
    }
  }
  // Each bucket is already frequency-sorted because allTechniques is sorted
  // by count; pushing preserves order.

  for (const tid of TACTIC_ORDER) {
    const meta = tactics[tid];
    if (!meta) continue;
    const techs = byTactic[tid] || [];
    const totalHits = techs.reduce((s, t) => s + t.count, 0);
    const color = TACTIC_COLORS[tid];
    const localMax = techs.length ? techs[0].count : 1;

    const card = document.createElement("div");
    card.className = "tactic-card";
    card.style.setProperty("--tactic-color", color);

    const displayTop = techs.slice(0, 5);
    const rows = displayTop.map(t => {
      const width = Math.round((t.count / localMax) * 100);
      return `
        <a class="mini-row" href="${BASE}/incidents?technique=${t.id}" style="--mini-w:${width}%">
          <span class="mini-name">${esc(t.name)}</span>
          <span class="mini-count">${t.count}</span>
        </a>
      `;
    }).join("");

    const extra = techs.length > 5 ? `<div class="tactic-more">+ ${techs.length - 5} more</div>` : "";
    const empty = !techs.length ? `<div class="tactic-empty">Not observed in corpus</div>` : "";

    card.innerHTML = `
      <div class="tactic-head">
        <div class="tactic-name">${esc(meta.name)}</div>
        <div class="tactic-count">${techs.length} tech · ${totalHits} hits</div>
      </div>
      <div class="tactic-list">${rows}${empty}</div>
      ${extra}
    `;
    chainGrid.appendChild(card);
  }
}

async function init() {
  try {
    const { freqData, metaData, stats } = await loadData();
    render(freqData, metaData, stats);
  } catch (err) {
    const container = document.querySelector(".anatomy")! as HTMLElement;
    container.innerHTML = `<div class="loading" style="color:var(--text-muted)">
      No data yet — run the analysis pipeline to populate the atlas.
    </div>`;
    console.error(err);
  }
}

init();
</script>

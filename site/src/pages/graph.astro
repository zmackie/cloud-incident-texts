---
import Base from "../layouts/Base.astro";
import AttackGraph from "../components/AttackGraph.astro";
---
<Base
  title="Attack Chain Graph"
  description="Force-directed graph of technique co-occurrence across all cloud incidents"
>
  <div class="page">
    <div class="page-header">
      <h1 class="page-title">Attack Chain Graph</h1>
      <p class="page-subtitle">
        Technique co-occurrence across all incidents. Edge thickness = how often two
        techniques appear consecutively in attack chains. Click a node to isolate its neighbors.
      </p>
    </div>

    <AttackGraph />

    <div class="tactic-legend"></div>
  </div>
</Base>

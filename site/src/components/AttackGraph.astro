---
// "How attackers move" — Sankey flow diagram of tactic transitions
// Replaces force-directed hairball with a readable kill-chain flow
---
<div id="flow-container">
  <div class="loading" id="flow-loading">Tracing flows…</div>
</div>

<div class="flow-legend">
  <div class="legend-note">
    <span class="legend-dot" style="background:var(--accent)"></span>
    Each ribbon traces a tactic-to-tactic transition observed in the attack chain of a real incident.
    Ribbon width = number of incidents making that move. Hover to see details.
    The Sankey layout requires a strict left-to-right order, so backward transitions
    (where attackers revisit an earlier kill-chain stage) are shown in the "Revisits &amp; loops" list below rather than on the diagram.
  </div>
</div>

<section class="top-flows">
  <div class="section-label">
    <span class="kicker">Chapter Three</span>
    <h2>Where attackers go next</h2>
  </div>
  <p class="section-lead">
    The ten most common <em>forward</em> tactic transitions in the corpus —
    what attackers do as they move through the kill chain.
  </p>
  <div id="top-flows-list"></div>

  <div class="section-label" style="margin-top:2.75rem">
    <span class="kicker">Chapter Four</span>
    <h2>Revisits &amp; loops</h2>
  </div>
  <p class="section-lead">
    The ten most common <em>backward</em> transitions — where attackers circled
    back to an earlier kill-chain stage. Re-running discovery after privilege
    escalation, planting persistence after exfiltration, and similar revisits.
  </p>
  <div id="back-flows-list"></div>
</section>

<div class="tooltip" id="flow-tooltip"></div>

<style is:global>
  #flow-container {
    width: 100%;
    height: 720px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }

  #flow-container svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .flow-legend {
    margin-top: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .legend-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 70ch;
  }

  .legend-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 0.4rem;
    vertical-align: 1px;
  }

  /* Sankey-specific styles (kept global so dynamically-injected SVG inherits) */
  .sankey-node-rect {
    cursor: pointer;
    transition: fill-opacity 0.15s, stroke-opacity 0.15s;
  }

  .sankey-node-label {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24;
    font-size: 0.88rem;
    font-weight: 500;
    fill: var(--text);
    pointer-events: none;
  }

  .sankey-node-sub {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    fill: var(--text-muted);
    pointer-events: none;
    letter-spacing: 0.04em;
  }

  .sankey-link {
    fill: none;
    opacity: 0.35;
    transition: opacity 0.15s;
    cursor: pointer;
  }

  .sankey-link:hover { opacity: 0.85 !important; }

  .sankey-dimmed .sankey-link:not(.sankey-link-active) { opacity: 0.08; }
  .sankey-dimmed .sankey-node-rect:not(.sankey-node-active) { fill-opacity: 0.25; stroke-opacity: 0.25; }

  /* Top flows list */
  .top-flows {
    margin-top: 3rem;
  }

  .top-flows .flow-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }
  .top-flows .flow-row:last-child { border-bottom: none; }

  .top-flows .flow-rank {
    font-family: var(--font-display);
    font-weight: 300;
    font-variation-settings: "opsz" 48;
    font-size: 1.5rem;
    color: var(--text-muted);
    font-feature-settings: "tnum";
    text-align: right;
  }

  .top-flows .flow-pair {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .top-flows .flow-tactic {
    font-family: var(--font-display);
    font-weight: 500;
    font-variation-settings: "opsz" 24;
    font-size: 1rem;
  }

  .top-flows .flow-arrow {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .top-flows .flow-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    min-width: 7rem;
    text-align: right;
  }

  .top-flows .flow-count b {
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
  }
</style>

<script>
import * as d3 from "d3";
import { sankey, sankeyLinkHorizontal, sankeyLeft } from "d3-sankey";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const DATA_BASE = `${BASE}/data`;

function esc(s: unknown): string {
  return String(s ?? "")
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

const TACTIC_COLORS: Record<string, string> = {
  "TA0043": "#e05252", "TA0042": "#e07852", "TA0001": "#e09e52",
  "TA0002": "#c5a832", "TA0003": "#8fb83e", "TA0004": "#4ab56e",
  "TA0005": "#3bb5a0", "TA0006": "#3898c5", "TA0007": "#4872c5",
  "TA0008": "#6456c5", "TA0009": "#9048c5", "TA0011": "#c548b5",
  "TA0010": "#c5486e", "TA0040": "#c5485a",
};

const TACTIC_ORDER = [
  "TA0043", "TA0042", "TA0001", "TA0002", "TA0003", "TA0004", "TA0005",
  "TA0006", "TA0007", "TA0008", "TA0009", "TA0011", "TA0010", "TA0040",
];

async function loadData() {
  const [graphData, metaData] = await Promise.all([
    fetch(`${DATA_BASE}/attack_graph.json`).then(r => r.ok ? r.json() : { nodes: [], edges: [] }),
    fetch(`${DATA_BASE}/attack_meta.json`).then(r => r.ok ? r.json() : {}),
  ]);
  return { graphData, metaData };
}

/**
 * Aggregate technique-level edges into tactic-level transitions.
 *
 * MITRE techniques routinely span multiple tactics (e.g. T1078 "Valid
 * Accounts" is both Initial Access and Persistence and Privilege
 * Escalation and Defense Evasion). Using only tactic_ids[0] would
 * misattribute transitions for those techniques. Instead, for each
 * edge we fan out across every (srcTactic × tgtTactic) pair and
 * distribute the edge's contribution by 1/(K×L) so the total count
 * contributed by one edge is preserved.
 *
 * Self-loops (same tactic both sides) are dropped — the Sankey and
 * ranked lists are about tactic-to-tactic movement, not intra-tactic
 * churn.
 */
function buildTacticFlows(graphData: any, metaData: any) {
  const techniques = metaData.techniques || {};
  const tactics = metaData.tactics || {};

  const flowMap = new Map<string, { src: string; tgt: string; count: number; incidents: Set<string> }>();
  const tacticUsage = new Map<string, { count: number; incidents: Set<string> }>();

  // Fallback: some edges reference technique IDs that aren't in attack_meta
  // (e.g. freshly ingested techniques, retired IDs). The graph node payload
  // carries a tactic_id for each technique, so consult that if the metadata
  // lookup comes up empty — avoids silently dropping those edges.
  const nodeTactic: Record<string, string> = {};
  for (const n of (graphData.nodes || [])) {
    if (n.tactic_id) nodeTactic[n.id] = n.tactic_id;
  }
  const tacticsFor = (tid: string): string[] => {
    const fromMeta = techniques[tid]?.tactic_ids || [];
    if (fromMeta.length) return fromMeta;
    return nodeTactic[tid] ? [nodeTactic[tid]] : [];
  };

  for (const edge of (graphData.edges || [])) {
    const srcTactics = tacticsFor(edge.source);
    const tgtTactics = tacticsFor(edge.target);
    if (!srcTactics.length || !tgtTactics.length) continue;

    // Enumerate all non-self-loop (srcT, tgtT) combinations for this edge.
    const pairs: Array<[string, string]> = [];
    for (const sT of srcTactics) {
      for (const tT of tgtTactics) {
        if (sT !== tT) pairs.push([sT, tT]);
      }
    }
    if (!pairs.length) continue;

    // Fan-out weighting: split the edge count across all contributing pairs
    // so techniques spanning many tactics don't over-contribute.
    const weight = (edge.count || 0) / pairs.length;
    for (const [sT, tT] of pairs) {
      const key = `${sT}→${tT}`;
      if (!flowMap.has(key)) flowMap.set(key, { src: sT, tgt: tT, count: 0, incidents: new Set() });
      const f = flowMap.get(key)!;
      f.count += weight;
      // Incidents are shared — same incident can legitimately contribute to
      // multiple tactic pairs for a multi-tactic technique, and that's
      // what we want to reflect in the Sankey width.
      for (const inc of (edge.incidents || [])) f.incidents.add(inc);
    }
  }

  // Tactic usage: sum across all tactic_ids for each node (same fallback
  // applied so nodes with only graph-level tactic_id still contribute).
  for (const node of (graphData.nodes || [])) {
    const tids = tacticsFor(node.id);
    if (!tids.length) continue;
    const share = (node.count || 0) / tids.length;
    for (const tid of tids) {
      if (!tacticUsage.has(tid)) tacticUsage.set(tid, { count: 0, incidents: new Set() });
      const u = tacticUsage.get(tid)!;
      u.count += share;
    }
  }

  return { flows: Array.from(flowMap.values()), tacticUsage, tactics };
}

function renderSankey(flowData: any, metaData: any) {
  const container = document.getElementById("flow-container")!;
  container.innerHTML = "";

  const { flows, tacticUsage, tactics } = flowData;

  const width = container.clientWidth;
  const height = container.clientHeight;

  // Sankey requires a DAG, so the visualization only renders forward
  // tactic transitions. Backward transitions still appear in the
  // "Revisits & loops" list below.
  const orderIdx: Record<string, number> = {};
  TACTIC_ORDER.forEach((t, i) => (orderIdx[t] = i));
  const forwardFlows = flows.filter((f: any) =>
    (orderIdx[f.src] ?? 99) < (orderIdx[f.tgt] ?? 99)
  );

  if (forwardFlows.length === 0) {
    const reason = flows.length === 0
      ? "No flow data available."
      : "No forward tactic transitions in corpus. See Revisits & loops below for backward transitions.";
    container.innerHTML = `<div class="loading" style="color:var(--text-muted);padding:2rem;text-align:center">${reason}</div>`;
    return;
  }

  // Nodes we need = all tactics referenced in forward flows
  const usedTactics = new Set<string>();
  for (const f of forwardFlows) { usedTactics.add(f.src); usedTactics.add(f.tgt); }

  const nodeList = TACTIC_ORDER.filter(t => usedTactics.has(t)).map(t => {
    const usage = tacticUsage.get(t) || { count: 0 };
    return {
      id: t,
      name: tactics[t]?.name || t,
      count: Math.round(usage.count),
      color: TACTIC_COLORS[t] || "#777",
    };
  });
  const nodeIndex: Record<string, number> = {};
  nodeList.forEach((n, i) => (nodeIndex[n.id] = i));

  // Size ribbons by incident count so the visual metric matches
  // what the ranked list and tooltips report.
  const sankeyData = {
    nodes: nodeList.map(n => ({ ...n })),
    links: forwardFlows.map((f: any) => ({
      source: nodeIndex[f.src],
      target: nodeIndex[f.tgt],
      value: Math.max(1, f.incidents.size),
      transitions: Math.round(f.count),
      incidents: f.incidents,
      srcId: f.src,
      tgtId: f.tgt,
    })),
  };

  const margin = { top: 24, right: 220, bottom: 24, left: 160 };

  const sk = sankey<any, any>()
    .nodeWidth(14)
    .nodePadding(18)
    .nodeAlign(sankeyLeft)
    .extent([[margin.left, margin.top], [width - margin.right, height - margin.bottom]]);

  const { nodes, links } = sk(sankeyData as any);

  const svg = d3.select(container)
    .append("svg")
    .attr("viewBox", `0 0 ${width} ${height}`)
    .attr("preserveAspectRatio", "xMidYMid meet");

  // Gradient defs — each link gets a left-color → right-color gradient
  const defs = svg.append("defs");
  (links as any[]).forEach((l: any, i: number) => {
    const grad = defs.append("linearGradient")
      .attr("id", `flow-grad-${i}`)
      .attr("gradientUnits", "userSpaceOnUse")
      .attr("x1", l.source.x1)
      .attr("x2", l.target.x0);
    grad.append("stop").attr("offset", "0%").attr("stop-color", l.source.color);
    grad.append("stop").attr("offset", "100%").attr("stop-color", l.target.color);
  });

  // Grid guides (vertical lines between columns, subtle)
  svg.append("g")
    .attr("stroke", "var(--border)")
    .attr("stroke-dasharray", "2,4")
    .attr("opacity", 0.25)
    .selectAll("line")
    .data(nodes)
    .join("line")
    .attr("x1", (d: any) => (d.x0 + d.x1) / 2)
    .attr("x2", (d: any) => (d.x0 + d.x1) / 2)
    .attr("y1", margin.top - 10)
    .attr("y2", height - margin.bottom + 10);

  // Links
  const linkSel = svg.append("g")
    .selectAll("path")
    .data(links as any[])
    .join("path")
    .attr("class", "sankey-link")
    .attr("d", sankeyLinkHorizontal() as any)
    .attr("stroke", (_d: any, i: number) => `url(#flow-grad-${i})`)
    .attr("stroke-width", (d: any) => Math.max(1, d.width));

  // Nodes
  const nodeSel = svg.append("g")
    .selectAll("g")
    .data(nodes as any[])
    .join("g");

  nodeSel.append("rect")
    .attr("class", "sankey-node-rect")
    .attr("x", (d: any) => d.x0)
    .attr("y", (d: any) => d.y0)
    .attr("width", (d: any) => d.x1 - d.x0)
    .attr("height", (d: any) => Math.max(4, d.y1 - d.y0))
    .attr("fill", (d: any) => d.color)
    .attr("stroke", (d: any) => d.color)
    .attr("stroke-width", 1);

  // Node labels — placed left for the first column, right for the last, top otherwise
  nodeSel.append("text")
    .attr("class", "sankey-node-label")
    .attr("x", (d: any) => d.x0 < width / 2 ? d.x1 + 10 : d.x0 - 10)
    .attr("y", (d: any) => (d.y0 + d.y1) / 2)
    .attr("dy", "0.35em")
    .attr("text-anchor", (d: any) => d.x0 < width / 2 ? "start" : "end")
    .text((d: any) => d.name);

  nodeSel.append("text")
    .attr("class", "sankey-node-sub")
    .attr("x", (d: any) => d.x0 < width / 2 ? d.x1 + 10 : d.x0 - 10)
    .attr("y", (d: any) => (d.y0 + d.y1) / 2 + 14)
    .attr("dy", "0.35em")
    .attr("text-anchor", (d: any) => d.x0 < width / 2 ? "start" : "end")
    .text((d: any) => `${esc(d.id)} · ${d.count} hits`);

  // Interactions
  const tip = document.getElementById("flow-tooltip")!;

  linkSel
    .on("mousemove", (event: MouseEvent, d: any) => {
      const srcName = d.source.name;
      const tgtName = d.target.name;
      const incCount = d.incidents?.size ?? 0;
      const examples = d.incidents ? Array.from(d.incidents as Set<string>).slice(0, 5) : [];
      tip.innerHTML = `
        <strong>${esc(srcName)} → ${esc(tgtName)}</strong>
        <div style="color:var(--text-muted);font-size:0.78rem;margin-top:4px">
          <b style="color:var(--accent)">${incCount}</b> incident${incCount !== 1 ? "s" : ""} · ${d.transitions} technique-level transition${d.transitions !== 1 ? "s" : ""}
        </div>
        ${examples.length ? `<div style="margin-top:6px;font-size:0.72rem;color:var(--text-muted);max-height:120px;overflow:auto">${examples.map(esc).join("<br>")}</div>` : ""}
      `;
      tip.classList.add("visible");
      const tipW = 340;
      const left = (event.clientX + 16 + tipW <= window.innerWidth - 8)
        ? event.clientX + 14
        : Math.max(8, event.clientX - tipW - 14);
      tip.style.left = left + "px";
      tip.style.top = Math.max(8, Math.min(event.clientY + 14, window.innerHeight - 220)) + "px";
    })
    .on("mouseleave", () => tip.classList.remove("visible"));

  nodeSel
    .on("mousemove", (event: MouseEvent, d: any) => {
      tip.innerHTML = `
        <span class="tid">${esc(d.id)}</span>
        <strong>${esc(d.name)}</strong>
        <div style="color:var(--text-muted);font-size:0.78rem;margin-top:4px">
          <b style="color:var(--accent)">${d.count}</b> technique hits across corpus
        </div>
      `;
      tip.classList.add("visible");
      const tipW = 340;
      const left = (event.clientX + 16 + tipW <= window.innerWidth - 8)
        ? event.clientX + 14
        : Math.max(8, event.clientX - tipW - 14);
      tip.style.left = left + "px";
      tip.style.top = Math.max(8, Math.min(event.clientY + 14, window.innerHeight - 220)) + "px";
    })
    .on("mouseleave", () => tip.classList.remove("visible"))
    .on("click", function(this: SVGGElement, _event: MouseEvent, d: any) {
      const svgEl = svg.node() as SVGSVGElement;
      if (svgEl.classList.contains("sankey-dimmed") && this.querySelector(".sankey-node-active")) {
        svgEl.classList.remove("sankey-dimmed");
        svg.selectAll(".sankey-node-active").classed("sankey-node-active", false);
        svg.selectAll(".sankey-link-active").classed("sankey-link-active", false);
        return;
      }
      svg.selectAll(".sankey-node-active").classed("sankey-node-active", false);
      svg.selectAll(".sankey-link-active").classed("sankey-link-active", false);
      svgEl.classList.add("sankey-dimmed");
      (this.querySelector(".sankey-node-rect") as any)?.classList.add("sankey-node-active");
      linkSel.each(function(this: SVGPathElement, l: any) {
        if (l.source.id === d.id || l.target.id === d.id) {
          this.classList.add("sankey-link-active");
          // Light up connected nodes
          const other = l.source.id === d.id ? l.target.id : l.source.id;
          nodeSel.filter((n: any) => n.id === other).select(".sankey-node-rect").classed("sankey-node-active", true);
        }
      });
    });
}

function renderFlowList(containerId: string, flows: any[], tactics: any, arrow: string, limit = 10) {
  const listEl = document.getElementById(containerId)!;
  listEl.innerHTML = "";
  if (!flows.length) {
    const row = document.createElement("div");
    row.className = "flow-row flow-empty";
    row.innerHTML = `<div></div><div style="color:var(--text-muted);font-style:italic">None observed.</div><div></div>`;
    listEl.appendChild(row);
    return;
  }
  const sorted = [...flows].sort((a: any, b: any) => b.incidents.size - a.incidents.size).slice(0, limit);
  const maxInc = sorted.length ? sorted[0].incidents.size : 1;

  sorted.forEach((f: any, i: number) => {
    const srcName = tactics[f.src]?.name || f.src;
    const tgtName = tactics[f.tgt]?.name || f.tgt;
    const srcColor = TACTIC_COLORS[f.src] || "#777";
    const tgtColor = TACTIC_COLORS[f.tgt] || "#777";
    const incCount = f.incidents.size;
    const barPct = Math.round((incCount / maxInc) * 100);

    const row = document.createElement("div");
    row.className = "flow-row";
    row.innerHTML = `
      <div class="flow-rank">${String(i + 1).padStart(2, "0")}</div>
      <div class="flow-pair">
        <span class="flow-tactic" style="color:${srcColor}">${esc(srcName)}</span>
        <span class="flow-arrow">${arrow}</span>
        <span class="flow-tactic" style="color:${tgtColor}">${esc(tgtName)}</span>
      </div>
      <div class="flow-count">
        <b>${incCount}</b> incident${incCount !== 1 ? "s" : ""}
        <div style="width:${barPct}%;height:2px;background:linear-gradient(90deg,${srcColor},${tgtColor});margin-top:4px;margin-left:auto"></div>
      </div>
    `;
    listEl.appendChild(row);
  });
}

function renderTopFlowsList(flowData: any) {
  const { flows, tactics } = flowData;
  const orderIdx: Record<string, number> = {};
  TACTIC_ORDER.forEach((t, i) => (orderIdx[t] = i));
  const forward = flows.filter((f: any) => (orderIdx[f.src] ?? 99) < (orderIdx[f.tgt] ?? 99));
  const backward = flows.filter((f: any) => (orderIdx[f.src] ?? 99) > (orderIdx[f.tgt] ?? 99));
  renderFlowList("top-flows-list", forward, tactics, "→", 10);
  renderFlowList("back-flows-list", backward, tactics, "↺", 10);
}

async function init() {
  try {
    const { graphData, metaData } = await loadData();
    const flowData = buildTacticFlows(graphData, metaData);
    renderSankey(flowData, metaData);
    renderTopFlowsList(flowData);
  } catch (err) {
    document.getElementById("flow-container")!.innerHTML =
      `<div class="loading" style="color:var(--text-muted)">Failed to load flow data.</div>`;
    console.error(err);
  }
}

init();
</script>
